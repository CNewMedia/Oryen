# Sanity — required for the site and embedded Studio at /studio
# Copy to .env.local in this folder (web/). Next does not load studio/.env.local.

# Your project id from https://www.sanity.io/manage (non-secret).
NEXT_PUBLIC_SANITY_PROJECT_ID=

# Dataset name (usually production).
NEXT_PUBLIC_SANITY_DATASET=production

# Required to run `npm run seed:cms` (create/replace CMS documents). Create at sanity.io/manage → API → Tokens.
SANITY_API_WRITE_TOKEN=

# Optional: same values under Studio-only names; Next maps them to NEXT_PUBLIC_* for /studio.
# SANITY_STUDIO_PROJECT_ID=
# SANITY_STUDIO_DATASET=production
