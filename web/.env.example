# Sanity — required for the site and embedded Studio at /studio
# Copy to .env.local in this folder (web/). Next does not load studio/.env.local.

# Your project id from https://www.sanity.io/manage (non-secret).
NEXT_PUBLIC_SANITY_PROJECT_ID=

# Dataset name (usually production).
NEXT_PUBLIC_SANITY_DATASET=production

# Optional: set to "true" to use Sanity's API CDN (faster GROQ; content can lag after Studio edits).
# Default is off so the site reads the latest published content and new image URLs.
# SANITY_USE_CDN=true

# Server-only: required for GROQ on a private dataset, or if your project requires authenticated reads.
# Create a read token at sanity.io/manage → API → Tokens (do not use NEXT_PUBLIC_).
# SANITY_API_READ_TOKEN=

# Required to run `npm run seed:cms` (create/replace CMS documents). Create at sanity.io/manage → API → Tokens.
SANITY_API_WRITE_TOKEN=

# Optional: same values under Studio-only names; Next maps them to NEXT_PUBLIC_* for /studio.
# SANITY_STUDIO_PROJECT_ID=
# SANITY_STUDIO_DATASET=production
